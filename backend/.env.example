# Database
DATABASE_URL="postgresql://user:password@localhost:5432/senda_inventory?schema=public"

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# JWT — access token (short-lived)
JWT_SECRET=change-me-to-a-long-random-string-32-chars-min
JWT_EXPIRES_IN=7d

# JWT — refresh token (long-lived, separate secret)
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=30d

# Sentry (optional — leave blank to disable error reporting)
SENTRY_DSN=

# Railway (set automatically in production)
# DATABASE_URL is injected by Railway from the linked Postgres plugin
