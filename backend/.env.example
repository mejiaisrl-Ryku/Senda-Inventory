# ─── Database ────────────────────────────────────────────────────────────────
#
# DATABASE_URL     — senda_app role (non-superuser, RLS enforced).
#                    PRODUCTION (single replica, no pgBouncer):
#                      postgresql://senda_app:<pw>@postgres.railway.internal:5432/railway
#                    PRODUCTION (multi-replica, WITH PgBouncer in transaction mode):
#                      postgresql://senda_app:<pw>@<pgbouncer-host>:5432/railway?pgbouncer=true
#                      Add ?pgbouncer=true so Prisma skips prepared-statement caching,
#                      which is incompatible with PgBouncer transaction mode.
#
# DIRECT_URL       — postgres superuser, direct connection (no pgBouncer).
#                    Used ONLY by `prisma migrate deploy` / `prisma generate`.
#                    Never used at runtime by the application.
#                    In Railway: postgres.railway.internal:5432
#                    REQUIRED when DATABASE_URL points to a pgBouncer host.
#
# ADMIN_DATABASE_URL — senda_admin role (BYPASSRLS).
#                    Used by prismaAdmin for KYRU_MANAGER cross-tenant queries.
#                    If unset, falls back to prisma (postgres superuser).
#
# DATABASE_POOL_SIZE — Prisma connection pool per process per role.
#                    Formula: floor(PG_MAX_CONNECTIONS / (roles × replicas)) - 2
#                    Railway Postgres default max_connections=100:
#                      1 replica,  3 roles → 31  (leave headroom for migrations)
#                      2 replicas, 3 roles → 14
#                      4 replicas, 3 roles →  6
#                    Default in code: 5 (safe for ≥4 replicas).
#                    Override in Railway env to tune without a deploy.
#
# DB_TRANSACTION_TIMEOUT_MS — max ms a transaction may hold a connection.
#                    Default: 15000 (15 s).  Prevents runaway queries starving pool.

DATABASE_URL="postgresql://senda_app:<password>@<host>:5432/railway"
DIRECT_URL="postgresql://postgres:<password>@postgres.railway.internal:5432/railway"
ADMIN_DATABASE_URL="postgresql://senda_admin:<password>@<host>:5432/railway"

DATABASE_POOL_SIZE=5
DB_TRANSACTION_TIMEOUT_MS=15000

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Access token (short-lived)
JWT_SECRET=change-me-to-a-long-random-string-32-chars-min
JWT_EXPIRES_IN=7d

# Refresh token (long-lived, separate secret)
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=30d

# ─── Redis ───────────────────────────────────────────────────────────────────
# Required for multi-replica deployments.  Shared rate-limit counters and
# cache are stored here so all replicas see consistent state.
# Without REDIS_URL: rate-limiters use in-memory store (per-replica, not shared)
# and caches degrade to DB-only reads.  Safe for single-replica dev; NOT for
# production with >1 Railway instance.
REDIS_URL=redis://default:<password>@<redis-host>:6379

# ─── Cache TTLs (seconds) ────────────────────────────────────────────────────
CACHE_TTL_FINANCIAL_S=300
CACHE_TTL_STATIC_S=1800

# ─── Rate limits ─────────────────────────────────────────────────────────────
API_RATE_LIMIT_MAX=300
API_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
FORGOT_PW_RATE_LIMIT_MAX=5
AI_RATE_LIMIT_MAX=20

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Set in Railway Variables for production / staging.
# When unset: error tracking is disabled (safe for local dev).
SENTRY_DSN=
# Fraction of requests to trace for performance (0.0 – 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.2

# ─── Logging ─────────────────────────────────────────────────────────────────
# Winston log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info
