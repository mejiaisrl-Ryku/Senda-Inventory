{
  "name": "senda-inventory-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "./node_modules/.bin/tsc",
    "start": "node dist/index.js",
    "start:prod": "npm run migrate && npm start",
    "migrate": "prisma db push --skip-generate --accept-data-loss",
    "test": "jest",
    "test:ci": "jest --ci --forceExit",
    "test:unit": "jest --testPathPattern='costing|stock|rateLimiter' --ci --forceExit",
    "test:integration": "jest --testPathPattern='tenantIntegrity|tenantIsolation|rlsPolicy' --ci --forceExit",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@prisma/client": "^5.6.0",
    "@sentry/node": "^7.99.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "rate-limit-redis": "^5.0.0",
    "resend": "^6.12.3",
    "socket.io": "^4.7.4",
    "winston": "^3.19.0",
    "zod": "^3.22.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^5.6.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
