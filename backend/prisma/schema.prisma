// Working copy — kept in sync with /database/schema.prisma (canonical source).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum Unit {
  KG
  LITERS
  PIECES
  LB
  OZ
  G
  EA
  DOZ
  CS
}

enum StockReason {
  RECEIVED
  USED
  ADJUSTED
  WASTE
}

enum OrderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum SalesCategory {
  BEER
  LIQUOR
  WINE
  FOOD
  NON_ALCOHOLIC
  EVENTS
  DELIVERY
  BUYOUTS
}

// Maps a product's COGS to one of the sales categories for cost-vs-revenue reporting.
enum COGSCategory {
  BEER
  LIQUOR
  WINE
  FOOD
  NON_ALCOHOLIC
}

// Which house a product belongs to for inventory views.
enum Department {
  BOH
  FOH
  BAR
  BOTH
}

// Department scope for a physical inventory count session.
enum CountDepartment {
  KITCHEN
  BAR
  FOH
  ALL
}

// Lifecycle of a count session.
enum CountStatus {
  OPEN
  CLOSED
}

// Department scope for a recipe.
enum RecipeDepartment {
  KITCHEN
  BAR
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model Restaurant {
  id          String    @id @default(cuid())
  name        String
  address     String?
  phone       String?
  logo        String?   // base64 data URL (PNG/JPG, max ~2.7 MB encoded)
  suspended   Boolean   @default(false)
  suspendedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users         User[]
  products      Product[]
  orders        Order[]
  salesEntries  SalesEntry[]
  laborEntries  LaborEntry[]
  countSessions CountSession[]
  recipes       Recipe[]

  @@map("restaurants")
}

model User {
  id           String     @id @default(cuid())
  name         String?
  email        String     @unique
  password     String
  role         Role       @default(STAFF)
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  stockLogs StockLog[]

  @@index([restaurantId])
  @@map("users")
}

model Product {
  id           String        @id @default(cuid())
  name         String
  sku          String?       @unique
  category     String?
  purveyor     String?
  invoiceDate  DateTime?     @db.Date
  department   Department    @default(BOH)
  cogsCategory COGSCategory?
  unit         Unit          @default(PIECES)
  costPerUnit  Float         @default(0)
  currentStock Float         @default(0)
  minimumStock Float         @default(0)
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  stockLogs         StockLog[]
  orderItems        OrderItem[]
  countEntries      CountEntry[]
  recipeIngredients RecipeIngredient[]

  @@index([restaurantId])
  @@map("products")
}

model StockLog {
  id               String      @id @default(cuid())
  productId        String
  product          Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  previousQuantity Float
  newQuantity      Float
  change           Float
  reason           StockReason
  timestamp        DateTime    @default(now())
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  notes            String?

  @@index([productId])
  @@index([userId])
  @@map("stock_logs")
}

model Order {
  id           String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status       OrderStatus @default(PENDING)
  totalCost    Float       @default(0)
  createdAt    DateTime    @default(now())
  deliveredAt  DateTime?

  orderItems OrderItem[]

  @@index([restaurantId])
  @@map("orders")
}

// Daily sales figures per category — used for COGS-vs-revenue reporting.
model SalesEntry {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date         DateTime      @db.Date
  category     SalesCategory
  amount       Decimal       @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime      @default(now())

  @@index([restaurantId])
  @@index([restaurantId, date])
  @@map("sales_entries")
}

// Explicit join table for Order <-> Product many-to-many.
// Stores quantity ordered and the unit cost locked at order time.
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
  unitCost  Float

  @@unique([orderId, productId])
  @@index([productId])
  @@map("order_items")
}

// Daily labor costs by role — used for labor-cost-% reporting against sales.
model LaborEntry {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date         DateTime   @db.Date
  fohLabor     Float      @default(0)
  bohLabor     Float      @default(0)
  management   Float      @default(0)
  total        Float      @default(0)
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
  @@index([restaurantId, date])
  @@map("labor_entries")
}

// A physical inventory count session (one per department per day).
model CountSession {
  id           String          @id @default(cuid())
  restaurantId String
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date         DateTime        @db.Date
  department   CountDepartment @default(ALL)
  status       CountStatus     @default(OPEN)
  createdBy    String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  entries CountEntry[]

  @@index([restaurantId])
  @@index([restaurantId, date])
  @@map("count_sessions")
}

// One line per product within a count session.
model CountEntry {
  id               String       @id @default(cuid())
  sessionId        String
  session          CountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId        String
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  expectedQuantity Decimal      @default(0) @db.Decimal(12, 3)
  actualQuantity   Decimal      @default(0) @db.Decimal(12, 3)
  variance         Decimal      @default(0) @db.Decimal(12, 3)   // actual − expected
  unitCost         Decimal      @default(0) @db.Decimal(12, 4)
  varianceValue    Decimal      @default(0) @db.Decimal(12, 2)   // variance × unitCost
  notes            String?
  createdAt        DateTime     @default(now())

  @@unique([sessionId, productId])
  @@index([sessionId])
  @@index([productId])
  @@map("count_entries")
}

// A costed recipe, belonging to a restaurant.
model Recipe {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  department   RecipeDepartment
  sellingPrice Decimal          @db.Decimal(10, 2)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  ingredients RecipeIngredient[]

  @@index([restaurantId])
  @@map("recipes")
}

// One ingredient line within a recipe.
model RecipeIngredient {
  id        String  @id @default(cuid())
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity         Decimal  @db.Decimal(12, 3)
  unit             String   // display unit (mirrors product.unit but stored as string for flexibility)
  conversionFactor Float?   // recipe-units per purchase-unit; null when units are auto-convertible or identical

  @@index([recipeId])
  @@index([productId])
  @@map("recipe_ingredients")
}
