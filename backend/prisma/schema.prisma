// Working copy — kept in sync with /database/schema.prisma (canonical source).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum Unit {
  KG
  LITERS
  PIECES
  LB
  OZ
  G
  EA
  DOZ
}

enum StockReason {
  RECEIVED
  USED
  ADJUSTED
  WASTE
}

enum OrderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum SalesCategory {
  BEER
  LIQUOR
  WINE
  FOOD
  NON_ALCOHOLIC
  EVENTS
  DELIVERY
}

// Maps a product's COGS to one of the sales categories for cost-vs-revenue reporting.
enum COGSCategory {
  BEER
  LIQUOR
  WINE
  FOOD
  NON_ALCOHOLIC
}

// Which house a product belongs to for inventory views.
enum Department {
  BOH
  FOH
  BAR
  BOTH
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model Restaurant {
  id        String    @id @default(cuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users        User[]
  products     Product[]
  orders       Order[]
  salesEntries SalesEntry[]
  laborEntries LaborEntry[]

  @@map("restaurants")
}

model User {
  id           String     @id @default(cuid())
  name         String?
  email        String     @unique
  password     String
  role         Role       @default(STAFF)
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  stockLogs StockLog[]

  @@index([restaurantId])
  @@map("users")
}

model Product {
  id           String        @id @default(cuid())
  name         String
  sku          String?       @unique
  category     String?
  purveyor     String?
  invoiceDate  DateTime?     @db.Date
  department   Department    @default(BOH)
  cogsCategory COGSCategory?
  unit         Unit          @default(PIECES)
  costPerUnit  Float         @default(0)
  currentStock Float         @default(0)
  minimumStock Float         @default(0)
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  stockLogs  StockLog[]
  orderItems OrderItem[]

  @@index([restaurantId])
  @@map("products")
}

model StockLog {
  id               String      @id @default(cuid())
  productId        String
  product          Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  previousQuantity Float
  newQuantity      Float
  change           Float
  reason           StockReason
  timestamp        DateTime    @default(now())
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  notes            String?

  @@index([productId])
  @@index([userId])
  @@map("stock_logs")
}

model Order {
  id           String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status       OrderStatus @default(PENDING)
  totalCost    Float       @default(0)
  createdAt    DateTime    @default(now())
  deliveredAt  DateTime?

  orderItems OrderItem[]

  @@index([restaurantId])
  @@map("orders")
}

// Daily sales figures per category — used for COGS-vs-revenue reporting.
model SalesEntry {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date         DateTime      @db.Date
  category     SalesCategory
  amount       Decimal       @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime      @default(now())

  @@index([restaurantId])
  @@index([restaurantId, date])
  @@map("sales_entries")
}

// Explicit join table for Order <-> Product many-to-many.
// Stores quantity ordered and the unit cost locked at order time.
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
  unitCost  Float

  @@unique([orderId, productId])
  @@index([productId])
  @@map("order_items")
}

// Daily labor costs by role — used for labor-cost-% reporting against sales.
model LaborEntry {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date         DateTime   @db.Date
  fohLabor     Float      @default(0)
  bohLabor     Float      @default(0)
  management   Float      @default(0)
  total        Float      @default(0)
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
  @@index([restaurantId, date])
  @@map("labor_entries")
}
