// Working copy — kept in sync with /database/schema.prisma (canonical source).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // DIRECT_URL bypasses PgBouncer for migrations and introspection.
  // Set to the postgres superuser connection (postgres.railway.internal)
  // in production.  Never used by the application at runtime.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  KYRU_MANAGER      // Kyru internal admin (replaces SUPER_ADMIN; kept during migration)
  OWNER_SUPER_ADMIN // Restaurant-group owner with cross-location access
  ADMIN             // Location admin
  STAFF             // Regular staff
  SUPER_ADMIN       // Legacy — remove after migrating existing records to KYRU_MANAGER
}

enum Unit {
  KG
  LITERS
  PIECES
  LB
  OZ
  G
  EA
  DOZ
  CS
}

enum StockReason {
  RECEIVED
  USED
  ADJUSTED
  WASTE
}

enum OrderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum SalesCategory {
  BEER
  LIQUOR
  WINE
  FOOD
  NON_ALCOHOLIC
  EVENTS
  DELIVERY
  BUYOUTS
}

// Which house a product belongs to for inventory views.
enum Department {
  BOH
  FOH
  BAR
  BOTH
}

// Department scope for a physical inventory count session.
enum CountDepartment {
  KITCHEN
  BAR
  FOH
  ALL
}

// Lifecycle of a count session.
enum CountStatus {
  OPEN
  CLOSED
}

// Department scope for a recipe.
enum RecipeDepartment {
  KITCHEN
  BAR
}

enum ScanJobType {
  INVOICE
  INVENTORY
}

enum ScanJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

// Owned by Kyru — one record per restaurant group (or single-location partner).
// Replaces the old self-referential groupId pattern on Restaurant.
model OwnerAccount {
  id        String   @id @default(cuid())
  name      String                          // Business / company name
  email     String   @unique

  active    Boolean  @default(true)         // Soft-delete flag
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurants    Restaurant[]
  cogsCategories CogsCategory[]
  users          User[]         @relation("OwnerAccountUsers")
  budgets        LocationBudget[]

  @@index([email])
  @@map("owner_accounts")
}

model Restaurant {
  id                   String    @id @default(cuid())
  name                 String
  address              String?
  phone                String?
  logo                 String?   // base64 data URL (PNG/JPG, max ~2.7 MB encoded)
  suspended            Boolean   @default(false)
  suspendedAt          DateTime?
  onboardingDismissed  Boolean   @default(false)
  locationCount        Int       @default(1)

  // Owner relationship — replaces old self-referential groupId pattern.
  // null = standalone or not yet assigned to an owner account.
  ownerAccountId String?
  ownerAccount   OwnerAccount? @relation(fields: [ownerAccountId], references: [id], onDelete: SetNull)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users             User[]
  products          Product[]
  orders            Order[]
  salesEntries      SalesEntry[]
  laborEntries      LaborEntry[]
  countSessions     CountSession[]
  recipes           Recipe[]
  budgets           LocationBudget[]
  toastConnection   ToastConnection?
  toastMenuItems    ToastMenuItem[]
  toastTransactions ToastTransaction[]
  scanJobs          ScanJob[]
  preparations      Preparation[]

  @@index([ownerAccountId])
  @@map("restaurants")
}

model User {
  id           String     @id @default(cuid())
  name         String?
  email        String     @unique
  password     String
  role         Role       @default(STAFF)

  // ADMIN / STAFF — linked to one location
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // OWNER_SUPER_ADMIN — linked to an owner account (cross-location access)
  ownerAccountId String?
  ownerAccount   OwnerAccount? @relation("OwnerAccountUsers", fields: [ownerAccountId], references: [id], onDelete: SetNull)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt

  stockLogs StockLog[]

  @@index([restaurantId])
  @@index([ownerAccountId])
  @@map("users")
}

model Product {
  id             String        @id @default(cuid())
  name           String
  sku            String?       @unique
  category       String?
  purveyor       String?
  invoiceDate    DateTime?     @db.Date
  department     Department    @default(BOH)
  cogsCategoryId String?
  cogsCategory   CogsCategory? @relation(fields: [cogsCategoryId], references: [id], onDelete: SetNull)
  unit           Unit          @default(PIECES)
  costPerUnit    Float         @default(0)
  currentStock   Float         @default(0)
  minimumStock   Float         @default(0)
  restaurantId   String
  restaurant     Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  stockLogs              StockLog[]
  orderItems             OrderItem[]
  countEntries           CountEntry[]
  recipeIngredients      RecipeIngredient[]
  preparationIngredients PreparationIngredient[]
  toastMenuItems         ToastMenuItem[]

  @@index([restaurantId])
  @@index([cogsCategoryId])
  @@map("products")
}

model StockLog {
  id               String      @id @default(cuid())
  productId        String
  product          Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  previousQuantity Float
  newQuantity      Float
  change           Float
  reason           StockReason
  unitCost         Float?      // snapshot of Product.costPerUnit at log time; null on legacy records
  timestamp        DateTime    @default(now())
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  notes            String?

  @@index([productId])
  @@index([userId])
  @@map("stock_logs")
}

model Order {
  id            String      @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status        OrderStatus @default(PENDING)
  totalCost     Float       @default(0)
  purveyor      String?
  invoiceDate   DateTime?   @db.Date
  invoiceNumber String?
  department    String?     // "KITCHEN" | "FOH" | "BAR" | null (all)
  createdAt     DateTime    @default(now())
  deliveredAt   DateTime?

  orderItems OrderItem[]

  @@index([restaurantId])
  @@index([restaurantId, createdAt])   // date-range queries in getLocationsOverview / getLocationsPricing
  @@map("orders")
}

// Daily sales figures per category — used for COGS-vs-revenue reporting.
model SalesEntry {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date         DateTime      @db.Date
  category     SalesCategory
  amount       Decimal       @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime      @default(now())

  @@index([restaurantId])
  @@index([restaurantId, date])
  @@map("sales_entries")
}

// One line item on a purchase invoice.
// productId is optional — invoices may contain free-form items not yet in
// the product catalogue.  When productId is set, receiving the order will
// update that product's stock automatically.
model OrderItem {
  id             String        @id @default(cuid())
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product?      @relation(fields: [productId], references: [id])
  productName    String?
  sku            String?
  category       String?
  unit           String?
  quantity       Float
  unitCost       Float
  cogsCategoryId String?
  cogsCategory   CogsCategory? @relation(fields: [cogsCategoryId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([cogsCategoryId])
  @@index([orderId, productName])      // product-name grouping in getLocationsPricing
  @@map("order_items")
}

// Daily labor costs by role — used for labor-cost-% reporting against sales.
model LaborEntry {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date         DateTime   @db.Date
  fohLabor     Float      @default(0)
  bohLabor     Float      @default(0)
  management   Float      @default(0)
  total        Float      @default(0)
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
  @@index([restaurantId, date])
  @@map("labor_entries")
}

// A physical inventory count session (one per department per day).
model CountSession {
  id           String          @id @default(cuid())
  restaurantId String
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date         DateTime        @db.Date
  department   CountDepartment @default(ALL)
  status       CountStatus     @default(OPEN)
  createdBy    String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  entries CountEntry[]

  @@index([restaurantId])
  @@index([restaurantId, date])
  @@index([restaurantId, status])      // quickly find latest CLOSED session per location
  @@map("count_sessions")
}

// One line per product within a count session.
model CountEntry {
  id               String       @id @default(cuid())
  sessionId        String
  session          CountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId        String
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  expectedQuantity Decimal      @default(0) @db.Decimal(12, 3)
  actualQuantity   Decimal      @default(0) @db.Decimal(12, 3)
  variance         Decimal      @default(0) @db.Decimal(12, 3)   // actual − expected
  unitCost         Decimal      @default(0) @db.Decimal(12, 4)
  varianceValue    Decimal      @default(0) @db.Decimal(12, 2)   // variance × unitCost
  notes            String?
  createdAt        DateTime     @default(now())

  @@unique([sessionId, productId])
  @@index([sessionId])
  @@index([productId])
  @@map("count_entries")
}

// A costed recipe, belonging to a restaurant.
model Recipe {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  department   RecipeDepartment
  sellingPrice Decimal          @db.Decimal(10, 2)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  portions          Int?
  batchWeight       Decimal?        @map("batch_weight") @db.Decimal(10, 2)
  preparationMethod String?         @map("preparation_method") @db.Text
  platingNotes      String?         @map("plating_notes") @db.Text
  photoUrl          String?         @map("photo_url") @db.VarChar(512)
  yieldPercent      Decimal?        @map("yield_percent") @db.Decimal(5, 2)
  category          RecipeCategory?
  station           KitchenStation?

  ingredients        RecipeIngredient[]
  toastMenuItems      ToastMenuItem[]
  recipePreparations  RecipePreparation[]
  recipeAllergens     RecipeAllergen[]

  @@index([restaurantId])
  @@index([restaurantId, name])
  @@map("recipes")
}

model Preparation {
  id                     Int               @id @default(autoincrement())
  restaurantId           String            @map("restaurant_id")
  restaurant             Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  name                   String            @db.VarChar(255)
  description            String?           @db.Text
  preparationMethod      String?           @map("preparation_method") @db.Text
  platingNotes           String?           @map("plating_notes") @db.Text
  photoUrl               String?           @map("photo_url") @db.VarChar(512)
  shelfLifeDays          Int?              @map("shelf_life_days")
  storageTemp            String?           @map("storage_temp") @db.VarChar(50)
  conservationType       ConservationType? @map("conservation_type")
  almacen                String?           @db.VarChar(100)
  recipeYield            Decimal?          @map("recipe_yield") @db.Decimal(10, 2)
  recipeYieldUnit        String?           @map("recipe_yield_unit") @db.VarChar(20)
  cost                   Decimal           @default(0) @db.Decimal(10, 4)
  costPerPortionEstimate Decimal?          @map("cost_per_portion_estimate") @db.Decimal(10, 4)
  currentStock           Float             @default(0) @map("current_stock")

  createdBy              String?           @map("created_by")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  recipePreparations     RecipePreparation[]
  preparationAllergens   PreparationAllergen[]
  preparationIngredients PreparationIngredient[]

  @@index([restaurantId])
  @@map("preparations")
}

model PreparationIngredient {
  id               String      @id @default(cuid())
  preparationId    Int         @map("preparation_id")
  preparation      Preparation @relation(fields: [preparationId], references: [id], onDelete: Cascade)
  productId        String      @map("product_id")
  product          Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity         Decimal     @db.Decimal(12, 3)
  unit             String
  conversionFactor Float?      @map("conversion_factor")

  @@index([preparationId])
  @@index([productId])
  @@map("preparation_ingredients")
}

model PreparationAllergen {
  id             Int         @id @default(autoincrement())
  preparationId  Int         @map("preparation_id")
  allergenId     Int         @map("allergen_id")

  preparation    Preparation @relation(fields: [preparationId], references: [id], onDelete: Cascade)
  allergen       Allergen    @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  createdAt      DateTime    @default(now()) @map("created_at")

  @@unique([preparationId, allergenId])
  @@index([preparationId])
  @@index([allergenId])
  @@map("preparation_allergens")
}

model RecipePreparation {
  id             Int         @id @default(autoincrement())
  recipeId       String      @map("recipe_id")
  preparationId  Int         @map("preparation_id")

  recipe         Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  preparation    Preparation @relation(fields: [preparationId], references: [id], onDelete: Cascade)

  quantity       Decimal?    @db.Decimal(10, 4)
  unit           String?     @db.VarChar(20)
  createdAt      DateTime    @default(now()) @map("created_at")

  @@unique([recipeId, preparationId])
  @@index([recipeId])
  @@index([preparationId])
  @@map("recipe_preparations")
}

model Allergen {
  id      Int    @id @default(autoincrement())
  code    String @unique @db.VarChar(50)
  labelEN String @map("label_en") @db.VarChar(100)
  labelES String @map("label_es") @db.VarChar(100)

  recipeAllergens      RecipeAllergen[]
  preparationAllergens PreparationAllergen[]

  @@map("allergens")
}

model RecipeAllergen {
  id                 Int      @id @default(autoincrement())
  recipeId           String   @map("recipe_id")
  allergenId         Int      @map("allergen_id")

  recipe             Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  allergen           Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  isPresent          Boolean  @default(true) @map("is_present")
  manuallyOverridden Boolean  @default(false) @map("manually_overridden")
  createdAt          DateTime @default(now()) @map("created_at")

  @@unique([recipeId, allergenId])
  @@index([recipeId])
  @@index([allergenId])
  @@map("recipe_allergens")
}

enum ConservationType {
  REFRIGERADO
  CONGELADO
  AMBIENTE

  @@map("conservation_type")
}

enum RecipeCategory {
  STARTER
  MAIN
  DESSERT
  SNACK
  BEVERAGE

  @@map("recipe_category")
}

enum KitchenStation {
  GRILL
  SAUCIER
  PANTRY
  PASTRY
  BAR
  FRYER

  @@map("kitchen_station")
}

// A pending invitation sent to a prospective partner (restaurant admin).
// Created when Super Admin sends an invite; token is a 64-char hex string.
// The onboarding flow claims the invite by presenting the token and sets
// status to "accepted" when the partner completes setup.
model PartnerInvite {
  id            String   @id @default(cuid())
  email         String   @unique
  firstName     String
  lastName      String
  token         String   @unique
  status        String   @default("pending")  // "pending" | "accepted"
  locationCount Int      @default(1)          // carried through to restaurant on setup
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([token])
  @@map("partner_invites")
}

// One ingredient line within a recipe.
model RecipeIngredient {
  id        String  @id @default(cuid())
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity         Decimal  @db.Decimal(12, 3)
  unit             String   // display unit (mirrors product.unit but stored as string for flexibility)
  conversionFactor Float?   // recipe-units per purchase-unit; null when units are auto-convertible or identical

  @@index([recipeId])
  @@index([productId])
  @@map("recipe_ingredients")
}

// ── COGS Categories ───────────────────────────────────────────────────────────

// Owner-defined COGS buckets (e.g. Beer, Liquor, Food).
// Replaces the old COGSCategory enum so each owner group can define its own list.
model CogsCategory {
  id             String       @id @default(cuid())
  name           String
  ownerAccountId String
  ownerAccount   OwnerAccount @relation(fields: [ownerAccountId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  products   Product[]
  orderItems OrderItem[]

  @@unique([ownerAccountId, name])
  @@index([ownerAccountId])
  @@map("cogs_categories")
}

// ── Audit log ─────────────────────────────────────────────────────────────────
//
// Append-only record of sensitive / irreversible actions.
// Written by lib/audit.ts — never deleted, never updated.
// Retained for compliance and incident investigation.

model AuditLog {
  id         String   @id @default(cuid())
  // Who performed the action (nullable for system/background jobs)
  actorId    String?
  actorRole  String?
  // What happened
  action     String   // e.g. "restaurant.hard_delete", "owner_account.hard_delete"
  // On which resource
  targetType String   // e.g. "restaurant", "owner_account", "user"
  targetId   String   // resource ID
  // Extra context (JSON blob — must be pre-scrubbed of PII by the caller)
  metadata   Json?
  // Request tracing
  requestId  String?
  ipAddress  String?

  createdAt  DateTime @default(now())

  @@index([action])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Budgeting ─────────────────────────────────────────────────────────────────

model LocationBudget {
  id              String       @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  ownerAccountId  String
  ownerAccount    OwnerAccount @relation(fields: [ownerAccountId], references: [id], onDelete: Cascade)
  year            Int
  month           Int?       // null = annual budget, 1–12 = monthly budget
  revenueTarget   Float
  laborPctTarget  Float      // target labor % (e.g. 35.0)
  primeCostTarget Float      // target prime cost % (e.g. 62.0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([restaurantId, year, month])
  @@index([restaurantId])
  @@index([ownerAccountId])
  @@map("location_budgets")
}

// ── Toast POS integration ─────────────────────────────────────────────────────
// One record per restaurant. Tokens stored AES-256-GCM encrypted.

model ToastConnection {
  id              String     @id @default(cuid())
  restaurantId    String     @unique
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  toastLocationId String
  accessToken     String     // AES-256-GCM encrypted
  refreshToken    String     // AES-256-GCM encrypted
  expiresAt       DateTime
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("toast_connections")
}

// ── Toast menu item → Kyru product mapping ───────────────────────────────────

model ToastMenuItem {
  id              String    @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  toastItemId     String    // Toast's internal menu item GUID
  toastItemName   String
  kyruProductId   String?   // FK to Product (null until manually mapped)
  product         Product?  @relation(fields: [kyruProductId], references: [id], onDelete: SetNull)
  kyruRecipeId    String?   // FK to Recipe — set when this menu item maps to a costed recipe
  recipe          Recipe?   @relation(fields: [kyruRecipeId], references: [id], onDelete: SetNull)
  lastSyncedAt    DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([restaurantId, toastItemId])
  @@index([restaurantId])
  @@index([kyruProductId])
  @@index([kyruRecipeId])
  @@map("toast_menu_items")
}

// ── Toast transaction audit log ───────────────────────────────────────────────
// Immutable once status = "synced". rawData preserves the original Toast JSON.

model ToastTransaction {
  id                  String     @id @default(cuid())
  restaurantId        String
  restaurant          Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  toastTransactionId  String     // Toast order / check GUID
  transactionDate     DateTime   // UTC — convert to local in the frontend
  amount              Float      // total transaction value
  category            String     // raw Toast category string
  itemDetails         Json       // [{toastItemId, name, qty, unitPrice}]
  rawData             Json       // original Toast JSON for audit
  status              String     @default("synced") // "synced" | "failed"
  syncedAt            DateTime   @default(now())
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([restaurantId, toastTransactionId])
  @@index([restaurantId])
  @@index([restaurantId, transactionDate])
  @@map("toast_transactions")
}

// ── Marketing leads (landing page) ───────────────────────────────────────────
// Pre-auth public capture — NO RLS, same category as users/restaurants.
// Written via the base `prisma` client (see controllers/leadsController.ts).

model Lead {
  id         String   @id @default(cuid())
  name       String
  restaurant String
  email      String?  // required by the API for new leads; null for pre-June-2026 rows
  locations  String   // "1" | "2" | "3" | "4+" — free string from the form
  phone      String
  language   String   // preferred account language: "en" | "es"
  pageLang   String   // landing page language at submit time
  source     String   @default("landing")
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@map("leads")
}

// Async Claude-Vision scan job — invoice extraction or inventory-count scan.
// Replaces the old synchronous flow (image in, Claude call awaited inline,
// result returned directly).  Image is uploaded to S3 first; a worker
// (separate process, see Sprint 2) picks up PENDING rows, calls Claude,
// and writes extractedData back here.
model ScanJob {
  id           String        @id @default(cuid())
  type         ScanJobType
  status       ScanJobStatus @default(PENDING)

  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  imageS3Url     String
  imageMimeType  String
  imageSizeBytes Int

  claudeModel        String   @default("claude-sonnet-4-5")
  inputTokens        Int?
  outputTokens       Int?
  claudeProcessingMs Int?

  extractedData   Json?
  extractionError String?

  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  lastRetryAt DateTime?

  webhookUrl       String?
  webhookDelivered DateTime?
  webhookError     String?

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  @@index([status])
  @@index([restaurantId])
  @@index([restaurantId, status])
  @@index([type])
  @@index([createdAt])
  @@map("scan_jobs")
}
