{
  "rewrites": [
    {
      "source": "/inicio",
      "destination": "/inicio.html"
    },
    {
      "source": "/((?!inicio|manifest\\.json|favicon\\.ico|icon-192\\.png|icon-512\\.png|service-worker\\.js|robots\\.txt|sitemap\\.xml|static/|assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://senda-inventory-production.up.railway.app/api"
  }
}
