# ── PUBLIC (safe for browser, baked into bundle at build time) ──────────────
# CRA requires the REACT_APP_ prefix for all client-side env vars.
# These are visible to users — never put secrets here.

# Backend API base URL (required)
REACT_APP_API_URL=http://localhost:4000/api

# Environment tag shown in Sentry events (development | staging | production)
REACT_APP_ENV=development

# Optional: release version shown in Sentry (set from CI, e.g. git short SHA)
REACT_APP_VERSION=

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Set in Vercel / Railway frontend environment variables.
# Leave blank in development — events will not be sent to Sentry.
REACT_APP_SENTRY_DSN=
# Fraction of transactions to sample for performance tracing (0.0 – 1.0)
REACT_APP_SENTRY_TRACES_RATE=0.2
# Sentry DSN for frontend error tracking (optional — app works without it)
# DSNs are designed to be public; Sentry rate-limits by project, not by DSN secrecy.
REACT_APP_SENTRY_DSN=

# ── BUILD FLAGS ──────────────────────────────────────────────────────────────

# Disable ESLint plugin during CRA build (avoids warnings-as-errors in CI)
DISABLE_ESLINT_PLUGIN=true

# Disable source map generation in production builds
# (set to false in .env.development.local if you want maps locally)
GENERATE_SOURCEMAP=false

# ── PRIVATE (backend only — never set these in the frontend) ─────────────────
# The following vars belong in Railway's environment variable settings.
# They are listed here for documentation only — do not add them to any
# frontend .env file.
#
# DATABASE_URL=postgresql://...
# JWT_SECRET=...
# JWT_REFRESH_SECRET=...
# ANTHROPIC_API_KEY=...    ← used server-side only for AI invoice scanning
# RESEND_API_KEY=...
